{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm:-rf *)",
      "Bash(rm:-rf /)",
      "Bash(rm:-rf ~)",
      "Bash(rm:-rf .)",
      "Bash(rm:-rf ./*)",
      "Bash(sqlite3:* DROP TABLE *)",
      "Bash(sqlite3:* DROP DATABASE *)",
      "Bash(git:push --force *)",
      "Bash(git:push -f *)",
      "Bash(git:reset --hard *)"
    ],
    "ask": [
      "Bash(rm:*bookshelf.db*)",
      "Bash(rm:*bookshelf.db)",
      "Bash(rm:bookshelf.db*)",
      "Bash(rm:backend/bookshelf.db*)",
      "Write(**/bookshelf.db)",
      "Edit(**/bookshelf.db)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(python -m pip install:*)",
      "Bash(rm:requirements.txt)",
      "Bash(rm:**/requirements.txt)"
    ],
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(uvicorn:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip freeze)",
      "Bash(pip3 freeze)",
      "Bash(pip list)",
      "Bash(curl:*localhost:8000*)",
      "Bash(curl:*127.0.0.1:8000*)",
      "Bash(sqlite3:*.db .tables)",
      "Bash(sqlite3:*.db .schema)",
      "Bash(sqlite3:*.db SELECT *)",
      "Read(**)",
      "Edit(backend/**)",
      "Edit(frontend/**)",
      "Edit(.claude/**)",
      "Write(backend/**)",
      "Write(frontend/**)",
      "Write(.claude/**)"
    ]
  }
}
